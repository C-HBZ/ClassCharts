# ClassCharts → Google Calendar Sync
# Environment variables template
#
# Copy this file to .env and fill in your real values.
# Keep .env private — it contains passwords and a private key.
#
# IMPORTANT: The script auto-discovers pupils from your ClassCharts account
# and matches each to a Google Calendar using GCAL_ID_<FIRSTNAME> (case-insensitive).
# For each child, add GCAL_ID_<FIRSTNAME> with their school calendar ID.
# Example: if your children are "Child1" and "Child2", add GCAL_ID_CHILD1 and GCAL_ID_CHILD2.

# ════════════════════════════════════════════════════════════════════════════
# ClassCharts credentials
# ════════════════════════════════════════════════════════════════════════════

CLASSCHARTS_EMAIL=your_parent_email@example.com
CLASSCHARTS_PASSWORD=your_classcharts_password

# ════════════════════════════════════════════════════════════════════════════
# Google service account (for Google Calendar API access)
# ════════════════════════════════════════════════════════════════════════════
#
# Steps to obtain this:
#
#   1. Go to https://console.cloud.google.com
#   2. Create (or select) a project
#   3. Enable the Google Calendar API
#   4. Create a Service Account (IAM & Admin → Service Accounts)
#   5. Generate a JSON key for the service account
#   6. Open the JSON file and copy its ENTIRE contents (all on one line)
#
# WARNING: This is a valid private key. Never commit it or share it.

GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"..."}

# ════════════════════════════════════════════════════════════════════════════
# Google Calendar IDs
# ════════════════════════════════════════════════════════════════════════════
#
# Find Calendar IDs in Google Calendar settings (Integrate calendar section).
#
# GCAL_ID_PARENT:  Your personal/primary calendar (usually your Gmail address)
#
# GCAL_ID_<FIRSTNAME>:  For each child, the calendar to sync their timetable into.
#   First name matching is case-insensitive.
#   Example: if a child's ClassCharts name is "Child1 Example",
#   add GCAL_ID_CHILD1 with their school calendar ID.
#
# Important: All these calendars must be shared with the service account
# (see README for details).

GCAL_ID_PARENT=parent@gmail.com
GCAL_ID_ALICE=alice_school_calendar_id@group.calendar.google.com
GCAL_ID_BOB=bob_school_calendar_id@group.calendar.google.com
# Add more GCAL_ID_<FIRSTNAME> as needed for additional children

# ════════════════════════════════════════════════════════════════════════════
# Optional: Homework event colours by child (leave blank for no colour)
# ════════════════════════════════════════════════════════════════════════════
#
# For each child, optionally assign a Google Calendar colour to their homework
# events. Use the child's first name (as appears in ClassCharts, case-insensitive).
#
# Colour IDs:  1=Lavender  2=Sage  3=Grape  4=Flamingo  5=Banana
#              6=Tangerine  7=Peacock  8=Graphite  9=Blueberry  10=Basil  11=Tomato

HOMEWORK_COLOR_ALICE=9
HOMEWORK_COLOR_BOB=3
